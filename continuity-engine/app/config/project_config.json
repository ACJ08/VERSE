{
  "project_id": "VERSE_DEMO",
  "engine_version": "0.1.0",

  "trust_levels": {
    "human": 1.0,
    "script": 0.8,
    "call_sheet": 0.65,
    "footage": 0.5,
    "ai_inference": 0.3
  },

  "category_weights": {
    "props": 1.0,
    "costume": 1.0,
