    "wears": ["costume", "wardrobe", "outfit", "clothing", "attire"],
    "location": ["place", "setting", "scene_location", "where"],
    "screen_position": ["position", "frame_position", "screen_direction", "blocking"],
    "movement": ["motion", "action_movement", "moves"],
    "lighting": ["light", "light_state", "illumination"]
  },

  "value_synonyms": {
    "left": ["left hand", "l", "left-hand", "lh"],
    "right": ["right hand", "r", "right-hand", "rh"],
    "blue_jacket": ["blue blazer", "navy jacket", "dark blue coat", "navy blazer"]
